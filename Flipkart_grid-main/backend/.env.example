# ── ParkWatch AI backend env (copy to .env) ──────────────────────────────────

# Groq LLM — powers the Tactical AI Commander. Without it, the agent returns
# deterministic explainable analysis (no external calls).
GROQ_API_KEY=your_groq_api_key_here

# JWT signing secret (change in production).
PARKWATCH_SECRET=change-me-in-production

# Extra CORS origins for production (comma-separated). Add your Vercel domain.
# e.g. https://parkwatch.vercel.app
CORS_ORIGINS=
